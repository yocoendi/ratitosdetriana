<!doctype html>
<html lang="en">

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-GLhlTQ8iRABdZLl6O3oVMWSktQOp6b7In1Zl3/Jr59b6EGGoI1aFkw7cmDA6j6gD" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-w76AqPfDkMBDXo30jS1Sgez6pr3x5MlQ1ZAGC+nuZB+EYdgRZgiwxhTBTkF7CXvN"
        crossorigin="anonymous"></script>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="">
    <meta name="author" content="Mark Otto, Jacob Thornton, and Bootstrap contributors">
    <meta name="generator" content="Hugo 0.108.0">
    <title>Update Proveedores</title>

    <link rel="canonical" href="https://getbootstrap.com/docs/5.3/examples/sign-in/">
    <link href="../../bootstrap-5.3.0-alpha1-examples/assets/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Custom styles for this template -->
    <link href="../styles.css" rel="stylesheet">
</head>

<body class="text-center">
    <% if (proveedores) {%>
    <main class="form-signin w-100 m-auto">
        <form action="/updateProveedores" method="POST">
            <img class="mb-4" src="../img/lugar.jpg" alt="" width="72" height="72">
            <input type="number" id="id" name="id" value="<%= proveedores.id %>">
            <h1 class="h3 mb-3 fw-normal">Registro Proveedores</h1>
            <div class="form-floating">
                <input type="text" class="form-control" id="cif" name="cif"  value="<%= proveedores.cif %>" placeholder="Cif...">
                <label for="floatingInput">Cif</label>
            </div>
            <div class="form-floating">
                <input type="text" class="form-control" id="name" name="name" value="<%= proveedores.name %>" placeholder="Nombre...">
                <label for="floatingInput">Nombre</label>
            </div>
            <div class="form-floating">
                <input type="text" class="form-control" id="address" name="address" value="<%= proveedores.address %>" placeholder="Dirección...">
                <label for="restaurantId">Dirección</label>
            </div>
            <div class="form-floating">
                <input type="text" class="form-control" id="state" name="state" value="<%= proveedores.state %>" placeholder="Pais...">
                <label for="floatingInput">Pais</label>
            </div>
            <div class="form-floating">
                <input type="text" class="form-control" id="zipCode" name="zipCode" value="<%= proveedores.zipCode %>" placeholder="Codigo Postal...">
                <label for="floatingInput">Codigo Postal</label>
            </div>
            <div class="form-floating">
                <input type="email" class="form-control" id="email" name="email"  value="<%= proveedores.email %>" placeholder="Email...">
                <label for="floatingInput">Email</label>
            </div>
            <div class="form-floating">
                <input type="text" class="form-control" id="restaurantId" name="restaurantId" value="<%= proveedores.restaurantId %>" placeholder="restaurantId...">
                <label for="floatingInput">Restaurante ID</label>
            </div>
            <div class="checkbox mb-3">
                <label>
                    <input type="checkbox" value="remember-me"> Acepto condiciones y términos
                </label>
            </div>
            <button class="w-100 btn btn-lg btn-primary" type="submit">Registrarse</button>
             <!-- Botón de cancelar -->
             <a class="w-100 btn btn-lg btn-secondary mt-2 px-4 py-2" href="/">Cancelar</a>
            <p class="mt-5 mb-3 text-muted">@ratitos</p>
        </form>
        <%} %>
    </main>
</body>

</html>