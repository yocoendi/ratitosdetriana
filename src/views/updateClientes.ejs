<!doctype html>
<html lang="en">

<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-GLhlTQ8iRABdZLl6O3oVMWSktQOp6b7In1Zl3/Jr59b6EGGoI1aFkw7cmDA6j6gD" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-w76AqPfDkMBDXo30jS1Sgez6pr3x5MlQ1ZAGC+nuZB+EYdgRZgiwxhTBTkF7CXvN"
        crossorigin="anonymous"></script>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Registro Admin</title>

    <link rel="canonical" href="https://getbootstrap.com/docs/5.3/examples/sign-in/">
    <link href="../../bootstrap-5.3.0-alpha1-examples/assets/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Custom styles for this template -->
    <link href="../styles.css" rel="stylesheet">
</head>

<body class="text-center">

    <% if (cliente) { %>

    <main class="form-signin w-100 m-auto">
        <form action="/updateClientes" method="POST">
            
            <img class="mb-4" src="../img/lugar.jpg" alt="" width="72" height="72">
            <input type="number" id="id" name="id" value="<%= cliente.id %>">
            <h1 class="h3 mb-3 fw-normal">Update Clientes</h1>

            <div class="form-floating">
                <label for="name" class="form-label">Nombre</label>
                <input type="text" class="form-control" id="name" name="name" vale="<%= cliente.name %>" placeholder="Nombre">
            </div>
            <div class="form-floating">
                <label for="surname" class="form-label">Apellido</label>
                <input type="text" class="form-control" id="surname" name="surname" vale="<%= cliente.surname %>" placeholder="Apellido">
            </div>
            <div class="form-floating">
                <label for="email" class="form-label">Email</label>
                <input type="email" class="form-control" id="email" name="email"  vale="<%= cliente.email %>" placeholder="Email">
            </div>
            <div class="form-floating">
                <label for="phone" class="form-label">Teléfono</label>
                <input type="text" class="form-control" id="phone" name="phone"  vale="<%= cliente.phone %>" placeholder="Teléfono">
            </div>
            <div class="form-floating">
                <label for="address" class="form-label">Dirección</label>
                <input type="text" class="form-control" id="address" name="address"  vale="<%= cliente.address %>" placeholder="Dirección">
            </div>
            <div class="form-floating">
                <label for="city" class="form-label">Ciudad</label>
                <input type="text" class="form-control" id="city" name="city" vale="<%= cliente.city %>" placeholder="Ciudad">
            </div>
            <div class="form-floating">
                <label for="state" class="form-label">Estado</label>
                <input type="text" class="form-control" id="state" name="state" vale="<%= cliente.state %>" placeholder="Estado">
            </div>
            <div class="form-floating">
                <label for="zipCode" class="form-label">Código Postal</label>
                <input type="text" class="form-control" id="zipCode" name="zipCode" vale="<%= cliente.ziCode %>" placeholder="Código Postal">

            <div class="checkbox mb-3">
                <label>
                    <input type="checkbox" value="remember-me"> Acepto condiciones y términos
                </label>
            </div>
            <button class="w-100 btn btn-lg btn-primary" type="submit">Modificar</button>
            <!-- Botón de cancelar -->
            <a class="w-100 btn btn-lg btn-secondary mt-2 px-4 py-2" href="/">Cancelar</a>
            
            <p class="mt-5 mb-3 text-muted">@ratitos</p>
        </form>

    <% } %>

    </main>
</body>

</html>
