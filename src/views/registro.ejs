<body class="text-center">

    <main class="form-signin w-100 m-auto">
        <form action="/registro" method="POST">
            <img class="mb-4" src="../img/lugar.jpg" alt="" width="72" height="72">
            <h1 class="h3 mb-3 fw-normal">Registro Admin</h1>
            <div class="form-floating">
                <input type="text" class="form-control" id="dni" name="dni" placeholder="Dni...">
                <label for="dni">Dni</label>
            </div>
            <div class="form-floating">
                <input type="text" class="form-control" id="username" name="username" placeholder="username...">
                <label for="username">User</label>
            </div>
            <div class="form-floating">
                <input type="email" class="form-control" id="email" name="email" placeholder="Email...">
                <label for="email">Email</label>
            </div>
            <div class="form-floating">
                <input type="text" class="form-control" id="restaurantId" name="restaurantId" placeholder="ID del restaurante...">
                <label for="restaurantId">ID del restaurante</label>
            </div>
            <div class="form-floating">
                <input type="password" class="form-control" id="password" name="password"
                    placeholder="Contraseña...">
                <label for="password">Contraseña</label>
            </div>
            <div class="checkbox mb-3">
                <label>
                    <input type="checkbox" value="remember-me"> Acepto condiciones y términos
                </label>
            </div>
            <button class="w-100 btn btn-lg btn-primary" type="submit">Registrarse</button>  
             <!-- Botón de cancelar -->
             <a class="w-100 btn btn-lg btn-secondary mt-2 px-4 py-2" href="/dashboard">Cancelar</a>   
            <p class="mt-5 mb-3 text-muted">@ratitos</p>
        </form>
    </main>
</body>

</html>