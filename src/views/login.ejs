<body class="text-center">

  <main class="form-signin w-100 m-auto">
    <form action="/auth" method="POST">
      <img class="mb-4" src="../img/lugar.JPG" alt="" width="72" height="72">
      <h1 class="h3 mb-3 fw-normal">Inicio Sesión</h1>

      <div class="form-floating">
        <input type="text" class="form-control" id="floatingInput" name="username" placeholder="User...">
        <label for="floatingInput">User</label>
      </div>
      <div class="form-floating">
        <input type="password" class="form-control" id="floatingPassword" name="password" placeholder="Contraseña...">
        <label for="floatingPassword">Contraseña</label>
      </div>

      <div class="checkbox mb-3">
        <label>
          <input type="checkbox" value="remember-me"> Recuerdame
        </label>
        <div class="form-group form-check">
          <a class="tdu text-thm" href="/password_reset/">Forgot Password?</a>
        </div>
      </div>
      <button class="w-100 btn btn-lg btn-primary" type="submit">Iniciar Sesión</button>
       <!-- Botón de cancelar -->
       <a class="w-100 btn btn-lg btn-secondary mt-2 px-4 py-2" href="/">Cancelar</a>
      
      
      <p class="mt-5 mb-3 text-muted">@ratitos</p>
    </form>
  </main>
</body>

</html>