generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id          Int          @id @default(autoincrement())
  restaurantId Int         @unique
  name        String
  address     String?
  city        String?
  state       String?
  zipCode     String?
  phone       String?
  email       String?
  website     String?
  empleados   Empleados[]
  proveedores Proveedores[]
  facturas    Facturas[]
  administradores Admin[]
}

model Empleados {
  id           Int        @id @default(autoincrement())
  dni          String     @unique
  firstName    String
  lastName     String
  position     String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId Int
}
model Proveedores {
  id           Int          @id @default(autoincrement())
  cif          String       @unique
  name         String
  address      String?
  state        String?
  zipCode      String?
  phone        String?
  email        String?
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id])
  restaurantId Int
  facturas     Facturas[]   @relation("ProveedorFacturas")
}

model Facturas {
  id              Int         @id @default(autoincrement())
  facturaNumber   String
  date            DateTime
  total           Float
  cif             String
  restaurant      Restaurant  @relation(fields: [restaurantId], references: [id])
  restaurantId    Int
  proveedor       Proveedores @relation("ProveedorFacturas", fields: [cif], references: [cif])
}




model Admin {
  id          Int        @id @default(autoincrement())
  dni         String     @unique
  email       String
  username    String     @unique
  password    String
  restaurant  Restaurant @relation(fields: [restaurantId], references: [id])
  restaurantId Int
}

model Cliente {
  id        Int     @id @default(autoincrement())
  name      String
  surname   String
  email     String  @unique
  phone     String?
  address   String?
  city      String?
  state     String?
  zipCode   String?
}
